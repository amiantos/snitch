{
    "discord": {
        "enabled": true,
        "token": "<DISCORD_BOT_TOKEN>",
        "discord_channel": "<DISCORD_CHANNEL_ID>",
        "irc_channel": "#yourchannel",
        "bridge_nick": "EyeBridge",
        "bridge_password": "<NICKSERV_PASSWORD>",
        "bridge_sasl": true,
        "channel_admin": {
            "enabled": true,
            "channel": "#yourchannel",
            "allowed_hosts": ["user/yourcloak"]
        }
    },
    "irc": {
        "host": "irc.libera.chat",
        "port": 6697,
        "tls": true,
        "max_line_length": 350
    },
    "github_webhook": {
        "enabled": true,
        "secret": "<GITHUB_WEBHOOK_SECRET>"
    },
    "discourse_webhook": {
        "enabled": true,
        "secret": "<DISCOURSE_WEBHOOK_SECRET>",
        "base_url": "https://discuss.example.com"
    },
    "postalgic_webhook": {
        "enabled": true,
        "secret": "<POSTALGIC_WEBHOOK_SECRET>"
    },
    "web": {
        "enabled": true,
        "port": 3002
    },
    "channel_log": {
        "enabled": true,
        "log_dir": "data/logs",
        "rotation": "monthly",
        "tail_lines": 100,
        "interval_seconds": 60,
        "r2": {
            "endpoint": "<R2_ENDPOINT_URL>",
            "bucket": "<R2_BUCKET>",
            "access_key_id": "<R2_ACCESS_KEY_ID>",
            "secret_access_key": "<R2_SECRET_ACCESS_KEY>",
            "key": "chat-log.txt"
        }
    }
}
